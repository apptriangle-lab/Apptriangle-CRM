            "url": {
              "raw": "{{base_url}}/api/integrations/food-allowances?month=2026-13",
              "host": ["{{base_url}}"],
              "path": ["api", "integrations", "food-allowances"],
              "query": [
                {
                  "key": "month",
                  "value": "2026-13"
                }
              ]
            },
            "description": "Expect 400: month must be in YYYY-MM format"
          },
          "response": []
        }
      ]
    },
