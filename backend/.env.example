# Copy to `.env` in this folder (CRM workspace root) before: docker compose up -d --build
#
# Quick start:
#   cp .env.docker.example .env
#   docker compose up -d --build
#   open http://localhost:8080
#
# Default login: admin@example.com / change-me  (change CRM_ADMIN_* below)

# --- Database (MySQL 8 container) ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=crm
MYSQL_USER=crm
MYSQL_PASSWORD=change-me-db
MYSQL_PORT=3307
PMA_ABSOLUTE_URI=http://localhost:8082/

# --- Backend ---
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret
JWT_EXPIRY_HOURS=0
CRM_ADMIN_EMAIL=admin@apptriangle.com
CRM_ADMIN_PASSWORD=password123
FRONTEND_URL=http://localhost:8080
EXTERNAL_API_KEY=crm_int_223c76cd2b9ebc855358c48d031f08bbacc22411b908b65e7dbffa99c36f4a43


# Optional email / integrations (leave blank to disable)
ZEPTOMAIL_API_TOKEN=
ZEPTOMAIL_FROM_EMAIL=
BREVO_API_KEY=
MAIL_SERVER=
MAIL_USERNAME=
MAIL_PASSWORD=
CREDENTIALS_FERNET_KEY=

# --- Published ports (VM: set FRONTEND_PORT=80) ---
FRONTEND_PORT=8080
PHPMYADMIN_PORT=8082
BACKEND_PORT=5000




